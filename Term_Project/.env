# HASA Open AI Service Hub의 OpenAI 호환 API 주소
# 포털의 API 문서에서 최신 Base URL을 확인한 뒤 필요하면 수정하세요.
HASA_BASE_URL=http://210.123.135.174:8080/v1

# 개발키를 여기에 입력하세요. 실제 키는 .env 파일에만 저장합니다.
HASA_API_KEY=
# 개발키에서 먼저 시도할 모델. 403이 나오면 phi-4로 바꾸세요.
CHAT_MODEL=phi-4
EMBEDDING_MODEL=bge-m3
RERANK_MODEL=bge-reranker-v2-m3

# true이면 검색 후보를 리랭커로 한 번 더 정렬합니다.
USE_RERANK=true
TOP_K=5
MAX_CONTEXT_CHARS=12000
HASA_TIMEOUT_SECONDS=90
